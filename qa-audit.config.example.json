{
  "projectPath": "./demo-project",
  "outputDir": "./reports",
  "api": {
    "baseUrl": "http://127.0.0.1:3100",
    "latencyWarnMs": 1000,
    "healthEndpoint": {
      "path": "/health",
      "expectedStatus": 200,
      "expectedContentType": "application/json"
    },
    "endpoints": [
      {
        "name": "Users",
        "path": "/api/users",
        "expectedStatus": 200,
        "expectedContentType": "application/json"
      }
    ]
  },
  "ui": {
    "baseUrl": "http://127.0.0.1:3100",
    "pages": [
      {
        "name": "Home",
        "path": "/"
      }
    ],
    "breakpoints": [
      {
        "name": "mobile",
        "width": 390,
        "height": 844
      },
      {
        "name": "desktop",
        "width": 1440,
        "height": 900
      }
    ],
    "failOnConsoleErrors": false
  },
  "ai": {
    "enabled": false,
    "provider": "openai",
    "model": "configure-with-env-if-enabled",
    "apiKeyEnv": "OPENAI_API_KEY"
  }
}
